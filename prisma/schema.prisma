// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/db/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

enum QuestionType {
  MULTIPLE_CHOICE
  TRUE_FALSE
  SHORT_ANSWER
  MATCHING
  CODE_SNIPPET
}

enum QuizStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum GradingStatus {
  CORRECT
  INCORRECT
  PARTIAL
  PENDING_MANUAL_REVIEW
}

model Quiz {
  id          String        @id @default(cuid())
  title       String
  description String?
  status      QuizStatus    @default(DRAFT)
  timeLimit   Int?          // Time limit in minutes (null means untimed)
  passingScore Int          @default(60) // Passing percentage (e.g., 60%)
  
  // Relations
  questions   Question[]
  submissions Submission[]
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
}

model Question {
  id          String        @id @default(cuid())
  quizId      String
  quiz        Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  
  type        QuestionType
  prompt      String        // The main question text/markdown
  points      Int           @default(1)
  order       Int           // To handle custom sorting of questions
  
  // JSON Blobs containing choices and grading answer keys
  // See structural examples below in the best practices section
  content     Json          // Handles: options, code snippets, matching items
  answerKey   Json          // Handles: correct index, exact string matches, true/false value

  // Relations
  responses   QuestionResponse[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([quizId])
}

// ==========================================
// Submissions & Grading Logic Models
// ==========================================

model Submission {
  id          String             @id @default(cuid())
  quizId      String
  quiz        Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId      String             // Links to your Auth provider User ID (NextAuth/Clerk)
  
  startedAt   DateTime           @default(now())
  completedAt DateTime?          // Track if they finished or ran out of time
  
  score       Int                @default(0)  // Final calculated total score
  percentage  Float              @default(0.0) // (score / totalPoints) * 100
  isPassed    Boolean            @default(false)

  // Relations
  responses   QuestionResponse[]

  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([quizId])
  @@index([userId])
}

model QuestionResponse {
  id           String        @id @default(cuid())
  submissionId String
  submission   Submission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  questionId   String
  question     Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  userAnswer   Json          // What the user submitted (string, index, or array)
  
  // Grading metrics filled on submission by your Next.js Server Action
  status       GradingStatus @default(PENDING_MANUAL_REVIEW)
  pointsEarned Int           @default(0)
  feedback     String?       // Explanatory note on why they got it right/wrong

  createdAt    DateTime      @default(now())

  @@unique([submissionId, questionId]) // Prevents answering the same question twice in one attempt
}